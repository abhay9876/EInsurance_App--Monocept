@{
    ViewData["Title"] = "Customer Dashboard";
    Layout = "_Layout";
}

<div class="container mt-4">

    <h3 class="mb-4">Customer Dashboard</h3>

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow-sm h-100 text-center">

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">My Policies</h5>

                    <p class="text-muted">
                        View all your purchased policies and payment details
                    </p>

                    <div class="mt-auto">
                        <a asp-action="MyPolicies" class="btn btn-primary w-100">
                            View
                        </a>
                    </div>

                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 text-center">

                <div class="card-body d-flex flex-column">

                    <h5 class="card-title">Available Policies</h5>

                    <p class="text-muted">
                        Browse and purchase new insurance policies
                    </p>

                    <div class="mt-auto">
                        <a asp-action="AvailablePolicies" class="btn btn-success w-100">
                            Explore
                        </a>
                    </div>

                </div>

            </div>
        </div>

        <a asp-action="PremiumCalculator" class="btn btn-warning w-100">
            Calculate Premium
        </a>

    </div>

</div>