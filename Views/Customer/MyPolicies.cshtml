@model List<Monocept.Models.Policy>

<h2>My Policies</h2>

<table class="table table-bordered table-striped mt-3">

    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Details</th>
            <th>Premium</th>
            <th>Scheme</th>
            <th>Payments</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.PolicyID</td>
                <td>@p.PolicyDetails</td>
                <td>@p.Premium</td>
                <td>@p.Scheme?.SchemeName</td>
                <td>
                    @foreach (var pay in p.Payments)
                    {
                        <div>@pay.Amount</div>
                    }
                </td>
            </tr>
        }
    </tbody>

</table>