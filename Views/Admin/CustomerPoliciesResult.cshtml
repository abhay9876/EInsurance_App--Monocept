@model List<Monocept.Models.Policy>

@{
    ViewData["Title"] = "Customer Policies";
    Layout = "_Layout";
}

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-body">

            <h4 class="mb-3">Policies for @ViewBag.Email</h4>
            <hr />

            @if (Model != null && Model.Count > 0)
            {
                <div class="table-responsive">

                    <table class="table table-bordered table-striped align-middle">

                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Details</th>
                                <th>Premium</th>
                                <th>Scheme</th>
                                <th>Payments</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var policy in Model)
                            {
                                <tr>
                                    <td>@policy.PolicyID</td>
                                    <td>@policy.PolicyDetails</td>
                                    <td>₹@policy.Premium</td>
                                    <td>@policy.Scheme?.SchemeName</td>
                                    <td>
                                        @if (policy.Payments != null && policy.Payments.Count > 0)
                                        {
                                            <ul class="mb-0">
                                                @foreach (var pay in policy.Payments)
                                                {
                                                    <li>
                                                        ₹@pay.Amount
                                                        <span class="text-muted">
                                                            (@pay.PaymentDate.ToShortDateString())
                                                        </span>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Payments</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>

                </div>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    No policies found for this customer.
                </div>
            }

        </div>

    </div>

</div>