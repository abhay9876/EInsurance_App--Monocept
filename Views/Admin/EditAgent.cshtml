@model Monocept.Models.InsuranceAgent

@{
    Layout = "_Layout";
}

<div class="d-flex justify-content-center mt-5">

    <div class="card shadow-sm" style="width: 400px;">

        <div class="card-body">

            <h4 class="text-center mb-3">Edit Agent</h4>
            <hr />

            <form method="post">

                <input type="hidden" name="AgentID" value="@Model.AgentID" />

                <div class="mb-3">
                    <label>Full Name</label>
                    <input name="FullName" value="@Model.FullName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Email</label>
                    <input name="Email" value="@Model.Email" class="form-control" />
                </div>

                <button class="btn btn-warning w-100">Update</button>

            </form>

        </div>

    </div>

</div>