@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}

<h2 class="mb-4">Admin Dashboard</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <h5 class="mb-3">Admin Panel</h5>
        <hr />

        <div class="row g-3">

            <div class="col-md-5">
                <div class="card">
                    <div class="card-body">

                        <h6>Search Customer Policies</h6>

                        <a asp-controller="Admin" asp-action="SearchCustomerPolicies"
                               class="btn btn-primary btn-sm mt-2">
                            Search
                        </a>

                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-body">

                        <h6>Manage Users</h6>

                        <a asp-controller="Admin" asp-action="ManageUsers"
                               class="btn btn-success btn-sm mt-2">
                            Open
                        </a>

                    </div>
                </div>
            </div>

        </div>

    </div>
</div>